{
  "expo": {
    "name": "Nana",
    "slug": "nana-expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nana",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nana.expensetracker",
      "infoPlist": {
        "NSCameraUsageDescription": "Nana needs camera access to scan your receipts",
        "NSPhotoLibraryUsageDescription": "Nana needs photo library access to select receipt images",
        "NSMicrophoneUsageDescription": "Nana needs microphone access for voice commands like 'Hey Nana'"
      }
    },
    "android": {
      "package": "com.nana.expensetracker",
      "adaptiveIcon": {
        "backgroundColor": "#0ea5e9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0ea5e9"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nana needs camera access to scan your receipts"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nana needs photo library access to select receipt images"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
